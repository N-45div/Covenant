{
  "name": "covenant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "next build apps/web",
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:web": "next dev apps/web",
    "deploy:stack": "XDG_CACHE_HOME=$PWD/.cache hardhat run contracts/scripts/deploy-stack.ts",
    "index:deployment": "tsx apps/worker/src/index-deployment.ts",
    "smoke:deployment": "XDG_CACHE_HOME=$PWD/.cache hardhat run contracts/scripts/smoke-deployment.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile:contracts": "XDG_CACHE_HOME=$PWD/.cache hardhat compile"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "hardhat": "^3.0.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "viem": "^2.23.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
